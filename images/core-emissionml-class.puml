@startuml core-emissionml-class
' EmissionML Abstract Conceptual Model (2026-02-04)
' EmissionEvent centered, relationships radiate outward

skinparam classAttributeIconSize 0
skinparam nodesep 40
skinparam ranksep 50
skinparam padding 3
skinparam classFontSize 13
skinparam classAttributeFontSize 11

' ── Top row: Source, SourceType, TemporalBound, EmissionQuantity, Mechanism ──
class Source {
  +name : CharacterString [0..1]
}

class SourceType {
  +label : CharacterString
  +description : CharacterString [0..1]
  +definition : URI
}

class TemporalBound {
  +time : TM_Instant [0..1]
  +quality : DQ_Element [0..*]
}

class TemporalStatus <<CodeList>> {
  known
  unknown
  ongoing
}

class EmissionQuantity {
  +value : Real
  +quality : DQ_Element [0..*]
}

class Mechanism {
  +label : CharacterString
  +description : CharacterString [0..1]
}

Source -[hidden]right- SourceType
SourceType -[hidden]right- TemporalBound
TemporalBound -[hidden]right- EmissionQuantity
EmissionQuantity -[hidden]right- UnitOfMeasure
UnitOfMeasure -[hidden]right- Mechanism

' ── Middle row: EmissionEvent ──
class EmissionEvent {
  +pollutantType : URI
}

' ── Bottom row: Observation, DeterminationProcedure ──
class Observation <<ISO 19156:2023>> {
}

class DeterminationProcedure {
  +label : CharacterString
  +description : CharacterString [0..1]
  +definition : URI [0..1]
}

Observation -[hidden]right- DeterminationProcedure

' ── Outer: leaf classes ──
class UnitOfMeasure {
  +label : CharacterString
  +symbol : CharacterString
  +definition : URI
}

class Feature <<ISO 19109>> {
  +geometry : GM_Object
}

class EmissionIntent <<CodeList>> {
  intentional
  unintentional
  unknown
}

class Procedure <<ISO 19156:2023>> {
}

note bottom of Observation : Observation per\nISO/OGC 19156:2023\n(OMS 3.0)

' ── Inheritance ──
Source -down-|> Feature
DeterminationProcedure -down-|> Procedure

' ── Layout: vertical alignment ──
TemporalBound -[hidden]down- EmissionEvent
EmissionQuantity -[hidden]down- EmissionEvent
Mechanism -[hidden]down- DeterminationProcedure
EmissionEvent -[hidden]down- Observation

' ── Layout: leaf positioning ──
Mechanism -[hidden]down- EmissionIntent

' ── Composition: up to TemporalBound ──
EmissionEvent "1" *-up- "1" TemporalBound : startTime
EmissionEvent "1" *-up- "1" TemporalBound : endTime

' ── Composition: up to EmissionQuantity (unit follows) ──
EmissionEvent "1" *-up- "1" EmissionQuantity : quantity
EmissionQuantity "1" *-down- "1" UnitOfMeasure : unit

' ── Association: up to Source ──
EmissionEvent "*" -up-> "1" Source : source

' ── Association: up-right to Mechanism ──
EmissionEvent "*" -up-> "1" Mechanism : mechanism

' ── Evidence: down to Observation ──
EmissionEvent "1" -down-> "*" Observation : quantityEvidence
EmissionEvent "1" -down-> "*" Observation : startTimeEvidence
EmissionEvent "1" -down-> "*" Observation : endTimeEvidence

' ── Basis: down to DeterminationProcedure ──
EmissionEvent "1" -down-> "1" DeterminationProcedure : startTimeBasis
EmissionEvent "1" -down-> "0..1" DeterminationProcedure : endTimeBasis
EmissionEvent "1" -down-> "1" DeterminationProcedure : quantityBasis

' ── Observation target ──
Observation "*" -left-> "1" Feature : ultimateFeatureOfInterest

' ── Leaf relationships ──
Source "*" -right-> "0..1" SourceType : type
Mechanism "*" -down-> "1" EmissionIntent : intent
TemporalBound "*" -right-> "1" TemporalStatus : status

@enduml
