<td id="_b0cbe4e7-1763-2151-07c0-dd1b95f54ed2" valign="middle" align="left">A human-readable name for the source.</td>
<td id="_2baf5d8f-675d-422c-a3d8-4157ef6f370d" valign="middle" align="left">String</td>
<td id="_dea5e937-3155-d805-e5bd-48f801f91342" valign="middle" align="left">0..1 (optional)</td>
</tr><tr id="_8fe40d93-270e-89d3-b0e3-260f78a0b218"><td id="_ffbedae5-a2e4-245d-ec77-fc12ca2d755b" valign="middle" align="left">geometry</td>
