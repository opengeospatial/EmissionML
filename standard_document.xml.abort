<td id="_3f2419e9-243e-0222-ebef-07e29bc4efa7" valign="middle" align="left">URI</td>
<td id="_36b85758-2188-95de-f3bc-b2cb1f61b5d6" valign="middle" align="left">0..1 (optional)</td>
</tr></tbody>
</table>

