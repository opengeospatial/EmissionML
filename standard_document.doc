<div><a name="_7d583d17-5edf-e0aa-b847-84641b5be6d1" id="_7d583d17-5edf-e0aa-b847-84641b5be6d1"></a><h3>A.1.13.<span style="mso-tab-count:1">&#xA0; </span>Procedure</h3>

<p class="TableTitle" style="text-align:center;">Table A.13</p><div align="center" class="table_container"><table class="MsoISOTable" style="mso-table-anchor-horizontal:column;mso-table-overlap:never;border-spacing:0;border-width:1px;" width="90%"><a name="_775675d6-7e0f-49f0-d72b-864cadbd448f" id="_775675d6-7e0f-49f0-d72b-864cadbd448f"></a><colgroup><col width="20%"/><col width="80%"/></colgroup><tbody><tr><td valign="middle" align="left" style="border-top:solid windowtext 1.5pt;mso-border-top-alt:solid windowtext 1.5pt;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="20.0%">Conformance class</td><td valign="middle" align="left" style="border-top:solid windowtext 1.5pt;mso-border-top-alt:solid windowtext 1.5pt;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="80.0%">/conf/datamodel/core/procedure</td></tr><tr><td valign="middle" align="left" style="border-top:none;mso-border-top-alt:none;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="20.0%">Requirements</td><td valign="middle" align="left" style="border-top:none;mso-border-top-alt:none;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="80.0%">/req/datamodel/core/procedure</td></tr><tr><td valign="middle" align="left" style="border-top:none;mso-border-top-alt:none;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="20.0%">Test purpose</td><td valign="middle" align="left" style="border-top:none;mso-border-top-alt:none;border-bottom:solid windowtext 1.0pt;mso-border-bottom-alt:solid windowtext 1.0pt;page-break-after:avoid;" width="80.0%">Verify that all requirements from the requirements class have been fulfilled.</td></tr><tr><td valign="middle" align="left" style="border-top:none;mso-border-top-alt:no